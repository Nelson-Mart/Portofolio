---
import Base from '../layouts/Base.astro';

const projects = [
  {
    id: 1,
    title: "Quiz App",
    description: "A mobile quiz application with multiple categories and score tracking.",
    stack: ["React Native", "TypeScript", "Expo"],
    type: "Mobile App",
    year: "2024",
    learned: [
      "Writing proper TypeScript types and interfaces",
      "Managing state across React Native screens",
      "Expo's build and deployment workflow",
      "Structuring a mobile app with clean navigation",
    ],
    github: "https://github.com/Nelson-Mart",
    live: null,
  },
  {
    id: 2,
    title: "Portfolio Website",
    description: "The site you're on right now. Built with Astro and Supabase.",
    stack: ["Astro", "Supabase", "CSS"],
    type: "Website",
    year: "2025",
    learned: [
      "Astro's file-based routing and layout system",
      "Connecting a frontend to Supabase",
      "CSS aurora / mesh gradient effects",
      "Deploying a static site with Vercel",
    ],
    github: "https://github.com/Nelson-Mart",
    live: "/",
  },
  {
    id: 3,
    title: "Full Stack Todo",
    description: "A full stack todo app with authentication and real-time updates.",
    stack: ["Next.js", "Prisma", "PostgreSQL", "Tailwind"],
    type: "Web App",
    year: "2024",
    learned: [
      "Next.js App Router and server components",
      "Database schema design with Prisma",
      "Auth with NextAuth.js",
      "Real-time UI updates with optimistic rendering",
    ],
    github: "https://github.com/Nelson-Mart",
    live: null,
  },
]

const typeColors: Record<string, string> = {
  "Mobile App": "#f59e0b",
  "Website":    "#22c55e",
  "Web App":    "#7b61ff",
}
---

<Base title="Projects">

  <!-- ── Header ───────────────────────────────────────── -->
  <section class="page-header">
    <p class="page-eyebrow">Work</p>
    <h1>Projects</h1>
    <p class="page-desc">
      Things I've built — personal projects, school work, and experiments.
      Click any card to see what I learned from it.
    </p>
  </section>

  <!-- ── Grid ─────────────────────────────────────────── -->
  <section class="projects-section">
    <div class="projects-grid">
      {projects.map(p => (
        <button
          class="project-card"
          data-project={JSON.stringify(p)}
          aria-label={`View details for ${p.title}`}
        >
          <div class="card-top">
            <span class="card-type" style={`color: ${typeColors[p.type] ?? 'var(--accent)'}`}>
              {p.type}
            </span>
            <span class="card-year">{p.year}</span>
          </div>

          <h2 class="card-title">{p.title}</h2>
          <p class="card-desc">{p.description}</p>

          <div class="card-stack">
            {p.stack.map(s => (
              <span class="stack-tag">{s}</span>
            ))}
          </div>

          <span class="card-cta">
            View details <i class="ti ti-arrow-right" aria-hidden="true"></i>
          </span>
        </button>
      ))}
    </div>
  </section>

  <!-- ── Modal ─────────────────────────────────────────── -->
  <div class="modal-backdrop" id="modal-backdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" id="modal">
      <button class="modal-close" id="modal-close" aria-label="Close">
        <i class="ti ti-x"></i>
      </button>

      <div class="modal-body">
        <div class="modal-top">
          <span class="modal-type" id="modal-type"></span>
          <span class="modal-year" id="modal-year"></span>
        </div>

        <h2 class="modal-title" id="modal-title"></h2>
        <p class="modal-desc" id="modal-desc"></p>

        <div class="modal-stack" id="modal-stack"></div>

        <div class="modal-section">
          <p class="modal-section-label">What I learned</p>
          <ul class="modal-learned" id="modal-learned"></ul>
        </div>

        <div class="modal-links" id="modal-links"></div>
      </div>
    </div>
  </div>

</Base>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />

<script>
  const backdrop = document.getElementById('modal-backdrop')!
  const modal    = document.getElementById('modal')!
  const closeBtn = document.getElementById('modal-close')!

  function openModal(data: any) {
    document.getElementById('modal-type')!.textContent  = data.type
    document.getElementById('modal-type')!.style.color  = getTypeColor(data.type)
    document.getElementById('modal-year')!.textContent  = data.year
    document.getElementById('modal-title')!.textContent = data.title
    document.getElementById('modal-desc')!.textContent  = data.description

    // Stack tags
    const stackEl = document.getElementById('modal-stack')!
    stackEl.innerHTML = data.stack.map((s: string) =>
      `<span class="stack-tag">${s}</span>`
    ).join('')

    // Learned list
    const learnedEl = document.getElementById('modal-learned')!
    learnedEl.innerHTML = data.learned.map((l: string) =>
      `<li>${l}</li>`
    ).join('')

    // Links
    const linksEl = document.getElementById('modal-links')!
    linksEl.innerHTML = ''
    if (data.github) {
      linksEl.innerHTML += `<a href="${data.github}" target="_blank" rel="noopener" class="modal-link">
        <i class="ti ti-brand-github"></i> GitHub
      </a>`
    }
    if (data.live) {
      linksEl.innerHTML += `<a href="${data.live}" target="_blank" rel="noopener" class="modal-link modal-link-primary">
        <i class="ti ti-external-link"></i> Live site
      </a>`
    }

    backdrop.setAttribute('aria-hidden', 'false')
    backdrop.classList.add('open')
    document.body.style.overflow = 'hidden'
    modal.focus()
  }

  function closeModal() {
    backdrop.classList.remove('open')
    backdrop.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  function getTypeColor(type: string) {
    const map: Record<string, string> = {
      'Mobile App': '#f59e0b',
      'Website':    '#22c55e',
      'Web App':    '#7b61ff',
    }
    return map[type] ?? 'var(--accent)'
  }

  // Open on card click
  document.querySelectorAll('.project-card').forEach(card => {
    card.addEventListener('click', () => {
      const data = JSON.parse((card as HTMLElement).dataset.project || '{}')
      openModal(data)
    })
  })

  // Close on backdrop click
  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal()
  })

  // Close button
  closeBtn.addEventListener('click', closeModal)

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal()
  })
</script>

<style is:global>
  .modal-learned {
    list-style: none;
    display: flex;
    flex-direction: column;
    padding: 0;
    margin: 0;
  }

  .modal-learned li {
    font-size: 0.875rem;
    color: var(--text);
    line-height: 1.6;
    padding: 10px 0;
    border-bottom: 1px solid var(--accent);
    opacity: 0.9;
  }

  .modal-learned li:first-child {
    border-top: 1px solid var(--accent);
  }

  .modal-learned li:last-child {
    border-bottom: none;
  }

  .modal-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
  }

  .modal-link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--bg));
  }

  .modal-link-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .modal-link-primary:hover {
    background: var(--accent-dim);
    border-color: var(--accent-dim);
  }

  .modal-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-tag {
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
  }
</style>

<style>
  /* ── Page header ─────────────────────────────────────── */
  .page-header {
    padding: 48px 0 56px;
    max-width: 560px;
  }

  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .page-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ── Grid ────────────────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* ── Card ────────────────────────────────────────────── */
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    background: var(--bg-card);
    border-radius: 10px;
    text-align: left;
    cursor: pointer;
    color: var(--text);
    font-family: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    border: none;
  }
  
  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 10px;
    padding: 1px;
    background: var(--border);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: background 0.3s;
  }
  
  .project-card:hover::before {
    background: conic-gradient(
      from var(--angle),
      #7b61ff,
      #06b6d4,
      #ec4899,
      #f59e0b,
      #7b61ff
    );
    animation: spin-gradient 2s linear infinite;
  }
  
  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }
  
  @property --angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }
  
  @keyframes spin-gradient {
    from { --angle: 0deg; }
    to   { --angle: 360deg; }
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-tag {
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
  }

  .card-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    transition: gap 0.15s;
  }

  .project-card:hover .card-cta {
    gap: 8px;
  }

  /* ── Modal backdrop ──────────────────────────────────── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Modal ───────────────────────────────────────────── */
  .modal {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    width: 100%;
    max-width: 520px;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(16px);
    transition: transform 0.2s;
    outline: none;
  }

  .modal-backdrop.open .modal {
    transform: translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    font-size: 1rem;
  }

  .modal-close:hover {
    color: var(--text);
    border-color: var(--text);
  }

  .modal-body {
    padding: 52px 32px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .modal-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .modal-year {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
  }

  .modal-title {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .modal-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .modal-section-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }


  .modal-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: 4px;
  }

  .modal-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
  }

  .modal-link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--bg));
  }

  .modal-link-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .modal-link-primary:hover {
    background: var(--accent-dim);
    border-color: var(--accent-dim);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 600px) {
    .modal-body { padding: 24px; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>