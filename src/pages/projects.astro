---
import Base from '../layouts/Base.astro';

const projects = [
{
  id: 1,
  title: "Quiz App",
  description: "A mobile quiz application with multiple categories and score tracking.",
  stack: ["React Native", "TypeScript", "Expo"],
  type: "Mobile App",
  year: "2024",
  image: null,
  learned: [
    "Writing proper TypeScript types and interfaces",
    "Managing state across React Native screens",
    "Expo's build and deployment workflow",
    "Structuring a mobile app with clean navigation",
  ],
  github: "https://github.com/Nelson-Mart",
  live: null,
},
{
  id: 2,
  title: "Portfolio Website",
  description: "The site you're on right now. Built with Astro and Supabase.",
  stack: ["Astro", "Supabase", "CSS"],
  type: "Website",
  year: "2025",
  image: "/portofolio.png",
  learned: [
    "Astro's file-based routing and layout system",
    "Connecting a frontend to Supabase",
    "CSS aurora / mesh gradient effects",
    "Deploying a static site with Vercel",
  ],
  github: "https://github.com/Nelson-Mart",
  live: "/",
},
{
  id: 3,
  title: "Full Stack Todo",
  description: "A full stack todo app with authentication and real-time updates.",
  stack: ["Next.js", "Prisma", "PostgreSQL", "Tailwind"],
  type: "Web App",
  year: "2024",
  image: null,
  learned: [
    "Next.js App Router and server components",
    "Database schema design with Prisma",
    "Auth with NextAuth.js",
    "Real-time UI updates with optimistic rendering",
  ],
  github: "https://github.com/Nelson-Mart",
  live: null,
},
{
  id: 4,
  title: "Test 1",
  description: "A small test project.",
  stack: ["HTML", "CSS"],
  type: "Website",
  year: "2025",
  image: null,
  learned: ["Basic project setup"],
  github: "https://github.com/Nelson-Mart",
  live: null,
},
{
  id: 5,
  title: "Test 2",
  description: "Another test project.",
  stack: ["JavaScript"],
  type: "Web App",
  year: "2025",
  image: null,
  learned: ["Basic project setup"],
  github: "https://github.com/Nelson-Mart",
  live: null,
},
]

const typeColors: Record<string, string> = {
  "Mobile App": "#f59e0b",
  "Website":    "#22c55e",
  "Web App":    "#7b61ff",
}
---

<Base title="Projects">

  <!-- ── Header ───────────────────────────────────────── -->
  <section class="page-header">
    <p class="page-eyebrow">Work</p>
    <h1>Projects</h1>
    <p class="page-desc">
      Things I've built — personal projects, school work, and experiments.
      Drag to browse, or use the arrows.
    </p>
  </section>

  <!-- ── Carousel ─────────────────────────────────────── -->
  <section class="carousel-section">
    <!-- Mobile hint - only visible on small screens -->
    <p class="mobile-hint">tap a card to expand</p>
    
    <div class="carousel-track-outer" id="carousel-outer">
      <div class="carousel-track" id="carousel-track">
        {projects.map((p, i) => (
          <div
            class="carousel-slide"
            data-index={i}
            data-project={JSON.stringify(p)}
          >
            <!-- Compact face (always visible on small cards, hidden on center) -->
            <div class="card-compact">
              <div class="card-top">
                <span class="card-type" style={`color: ${typeColors[p.type] ?? 'var(--accent)'}`}>
                  {p.type}
                </span>
                <span class="card-year">{p.year}</span>
              </div>
              <h2 class="card-title">{p.title}</h2>
              <p class="card-desc">{p.description}</p>
              <div class="card-stack">
                {p.stack.map(s => <span class="stack-tag">{s}</span>)}
              </div>
            </div>

            <!-- Expanded face (only visible on center card) -->
            <div class="card-expanded" aria-hidden="true">
              <!-- Image zone -->
              <div class="card-image-zone">
                {p.image
                  ? <img src={p.image} alt={`${p.title} preview`} class="card-image" />
                  : (
                    <div class="card-image-placeholder">
                      <span class="placeholder-title">{p.title}</span>
                      <span class="placeholder-type" style={`color: ${typeColors[p.type] ?? 'var(--accent)'}`}>{p.type}</span>
                    </div>
                  )
                }
              </div>

              <!-- Meta row -->
              <div class="expanded-meta">
                <div class="card-top">
                  <span class="card-type" style={`color: ${typeColors[p.type] ?? 'var(--accent)'}`}>
                    {p.type}
                  </span>
                  <span class="card-year">{p.year}</span>
                </div>
                <h2 class="card-title">{p.title}</h2>
                <p class="card-desc">{p.description}</p>
                <div class="card-stack">
                  {p.stack.map(s => <span class="stack-tag">{s}</span>)}
                </div>
              </div>

              <!-- What I learned + Links (hidden during peek, shown when fully snapped) -->
              <div class="expanded-details">
                <div class="expanded-learned">
                  <p class="section-label">What I learned</p>
                  <ul class="learned-list">
                    {p.learned.map(l => <li>{l}</li>)}
                  </ul>
                </div>

                <div class="expanded-links">
                  {p.github && (
                    <a href={p.github} target="_blank" rel="noopener" class="link-btn link-ghost">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2c2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2a4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2a4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6.6-.6 1.2-.5 2v3.5"/></svg>
                      GitHub
                    </a>
                  )}
                  {p.live && (
                    <a href={p.live} target="_blank" rel="noopener" class="btn btn-primary">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 6h-6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"/><path d="M11 13l9-9"/><path d="M15 4h5v5"/></svg>
                      Live site
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Dot indicators -->
    <p class="carousel-label">drag to view projects</p>
    <div class="carousel-dots" id="carousel-dots" aria-label="Carousel position">
      {projects.map((_, i) => (
        <button class="dot" data-dot={i} aria-label={`Go to project ${i + 1}`}></button>
      ))}
    </div>
  </section>

</Base>

<script>
  const CARD_W      = 260
  const CARD_PEEK   = 360
  const CARD_BIG    = 460
  const GAP         = 28
  const SCALE_SMALL = 0.80
  const SCALE_PEEK  = 0.92
  const SNAP_THRESH = 30

  const outer  = document.getElementById('carousel-outer')!
  const track  = document.getElementById('carousel-track')!
  const dotsEl = document.getElementById('carousel-dots')!
  const slides = Array.from(track.querySelectorAll('.carousel-slide')) as HTMLElement[]
  const dots   = Array.from(dotsEl.querySelectorAll('.dot')) as HTMLButtonElement[]
  const N      = slides.length

  let currentIndex = Math.floor(N / 2)
  let peekIndex    = -1
  let offsetX      = 0
  let isDragging   = false
  let dragStartX   = 0
  let dragStartOff = 0
  let hasDragged   = false
  let expandedMobileIndex: number | null = null

  const isSmallScreen = () => window.innerWidth < 640

  function updateLayoutMode() {
    if (isSmallScreen()) {
      outer.classList.add('grid-mode')
    } else {
      outer.classList.remove('grid-mode')
    }
  }

  updateLayoutMode()
  window.addEventListener('resize', () => {
    updateLayoutMode()
    if (!isSmallScreen()) snapToIndex(currentIndex, false)
  })

  function cardW(i: number, progress = 0): number {
    const delayed = Math.max(0, (progress - 0.25) / 0.75)

    if (i === currentIndex) {
      return CARD_BIG - (CARD_BIG - CARD_PEEK) * progress
    }
    if (i === peekIndex) {
      return CARD_W + (CARD_PEEK - CARD_W) * delayed
    }
    return CARD_W
  }

  /* ─── Compute all card positions in one pass ──── */
  function layoutPositions(progress = 0) {
    const outerW  = outer.offsetWidth
    const center  = outerW / 2
    const positions: number[] = []
    let pos = 0
    for (let i = 0; i < N; i++) {
      positions.push(pos)
      pos += cardW(i, progress) + GAP
    }
    const midW  = cardW(currentIndex, progress)
    const snapX = outerW / 2 - (positions[currentIndex] + midW / 2)
    return { positions, center, snapX }
  }

  /* ─── Details helper ───────────────────────────── */
  function setDetails(el: HTMLElement | null, vis: number, dur: string) {
    if (!el) return
    el.style.transition = `max-height ${dur} cubic-bezier(.4,0,.2,1), opacity ${dur} ease`
    el.style.maxHeight  = `${vis * 400}px`
    el.style.opacity    = String(vis)
    el.classList.toggle('open', vis > 0.01)
  }

  /* ─── Apply visual state to all slides ────────── */
  function applyLayout(animated: boolean, progress = 0) {
    if (isSmallScreen()) return
    const dur  = animated ? '0.38s' : '0.40s'
    const ease = 'cubic-bezier(.4,0,.2,1)'

    slides.forEach((slide, i) => {
      const isFull = i === currentIndex
      const isPeek = i === peekIndex
      const compact  = slide.querySelector('.card-compact')  as HTMLElement
      const expanded = slide.querySelector('.card-expanded') as HTMLElement
      const details  = slide.querySelector('.expanded-details') as HTMLElement | null

      let width   = cardW(i, progress)
      let scale   = isFull ? 1 - (1 - SCALE_PEEK) * progress : isPeek ? SCALE_PEEK : SCALE_SMALL
      let opacity = isFull ? 1 - 0.15 * progress             : isPeek ? 0.85        : 0.45

      slide.style.transition = `width ${dur} ${ease}, transform ${dur} ${ease}, opacity ${dur} ease`
      slide.style.width      = `${width}px`
      slide.style.transform  = `scale(${scale})`
      slide.style.opacity    = String(opacity)
      slide.dataset.center   = String(isFull)

      if (isFull) {
        compact.style.display  = 'none'
        expanded.style.display = 'flex'
        expanded.setAttribute('aria-hidden', 'false')
        setDetails(details, Math.max(0, 1 - progress * 1.2), dur)
      } else if (isPeek) {
        compact.style.display  = 'none'
        expanded.style.display = 'flex'
        expanded.setAttribute('aria-hidden', 'true')
        setDetails(details, 0, dur)
      } else {
        compact.style.display  = 'flex'
        expanded.style.display = 'none'
        expanded.setAttribute('aria-hidden', 'true')
        setDetails(details, 0, dur)
      }
    })

    dots.forEach((dot, i) => dot.classList.toggle('active', i === currentIndex))
  }

  function snapToIndex(idx: number, animated = true) {
    if (isSmallScreen()) return
    currentIndex = Math.max(0, Math.min(N - 1, idx))
    peekIndex    = -1
    applyLayout(animated)
    const go = () => {
      offsetX = layoutPositions().snapX
      track.style.transition = animated ? `transform 0.38s cubic-bezier(.4,0,.2,1)` : 'none'
      track.style.transform  = `translateX(${offsetX}px)`
    }
    if (animated) requestAnimationFrame(go); else go()
  }

  function nearestIndex(): number {
    const { positions, center } = layoutPositions()
    let best = 0, bestDist = Infinity
    for (let i = 0; i < N; i++) {
      const dist = Math.abs(offsetX + positions[i] + cardW(i) / 2 - center)
      if (dist < bestDist - 5) { bestDist = dist; best = i }
    }
    return best
  }

  // tells how far from center you are dragging
  function dragProgress(): { progress: number; dist: number } {
    const { positions, center } = layoutPositions()
    const w    = cardW(currentIndex)
    const dist = Math.abs(offsetX + positions[currentIndex] + w / 2 - center)
    let p = Math.min(dist / 194, 1)
    p = p * p * (3 - 2 * p)
    return { progress: p, dist }
  }

  function onPointerDown(e: PointerEvent) {
    if (isSmallScreen()) return
    isDragging = true; hasDragged = false
    dragStartX = e.clientX; dragStartOff = offsetX
    track.style.transition = 'none'
    track.setPointerCapture(e.pointerId)
  }

  function onPointerMove(e: PointerEvent) {
    if (isSmallScreen()) return
    if (!isDragging) return
    const delta = e.clientX - dragStartX
    if (Math.abs(delta) > 4) hasDragged = true
    offsetX = dragStartOff + delta
    track.style.transform = `translateX(${offsetX}px)`

    const { progress, dist } = dragProgress()
    const nearest = nearestIndex()
    if (nearest !== currentIndex && dist > SNAP_THRESH) {
      peekIndex = nearest
      applyLayout(false, Math.min(progress * 1.1, 1))
    } 
    else {
      peekIndex = -1
      applyLayout(false, Math.min(progress * 0.7, 1))
    }
  }

  function onPointerUp() {
    if (isSmallScreen()) return
    if (!isDragging) return
    isDragging = false
    if (!hasDragged) return
    const { progress, dist } = dragProgress()
    const nearest = nearestIndex()
    if (peekIndex !== -1 && progress > 0.3 && dist > SNAP_THRESH) snapToIndex(peekIndex)
    else if (nearest !== currentIndex && dist > SNAP_THRESH) snapToIndex(nearest)
    else snapToIndex(currentIndex)
    peekIndex = -1
  }

  track.addEventListener('pointerdown',  onPointerDown)
  track.addEventListener('pointermove',  onPointerMove)
  track.addEventListener('pointerup',    onPointerUp)
  track.addEventListener('pointercancel', onPointerUp)
  track.addEventListener('dragstart',    e => e.preventDefault())

  // ─── Mobile: click to expand ──────────────────────────
  function toggleMobileExpand(index: number) {
    if (!isSmallScreen()) return
    
    const slide = slides[index]
    const compact = slide.querySelector('.card-compact') as HTMLElement
    const expanded = slide.querySelector('.card-expanded') as HTMLElement
    const details = slide.querySelector('.expanded-details') as HTMLElement | null
    
    // If clicking the same card that's expanded, collapse it
    if (expandedMobileIndex === index) {
      slide.classList.remove('expanded')
      expandedMobileIndex = null
      return
    }
    
    // Close any previously expanded card
    if (expandedMobileIndex !== null) {
      const prevSlide = slides[expandedMobileIndex]
      prevSlide.classList.remove('expanded')
    }
    
    // Expand the clicked card
    slide.classList.add('expanded')
    expandedMobileIndex = index
  }

  // Click handler for all slides - works on both desktop and mobile
  slides.forEach((slide, i) => {
    slide.addEventListener('click', (e) => {
      if (isSmallScreen()) {
        // On mobile, toggle expansion
        toggleMobileExpand(i)
        // Prevent the click from triggering other actions
        e.stopPropagation()
      } else {
        // On desktop, navigate to the clicked card
        if (!hasDragged && i !== currentIndex) snapToIndex(i)
      }
    })
  })

  dots.forEach((dot, i) => dot.addEventListener('click', () => snapToIndex(i)))
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') snapToIndex(currentIndex + 1)
    if (e.key === 'ArrowLeft')  snapToIndex(currentIndex - 1)
  })

  // Collapse when clicking outside
  document.addEventListener('click', (e) => {
    if (!isSmallScreen()) return
    if (expandedMobileIndex === null) return
    const target = e.target as HTMLElement
    if (!target.closest('.carousel-slide')) {
      const slide = slides[expandedMobileIndex]
      slide.classList.remove('expanded')
      expandedMobileIndex = null
    }
  })

  requestAnimationFrame(() => snapToIndex(currentIndex, false))
</script>

<style>
  /* ── Page header ──────────────────────────────── */
  .page-header {
    padding: 48px 0 52px;
    max-width: 560px;
  }
  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .page-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ── Carousel ───────────────────────────────── */
  .carousel-section { padding-bottom: 56px; }

  /* Mobile hint - hidden by default, shown on small screens */
  .mobile-hint {
    display: none;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .carousel-track-outer {
    display: flex;
    align-items: center;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    height: 728px;
    touch-action: pan-y;
  }
  .carousel-track-outer:active { cursor: grabbing; }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 28px 0 36px;
    will-change: transform;
  }

  /* GRID MODE */
  #carousel-outer.grid-mode {
    overflow: visible;
    height: auto;
    mask-image: none;
    -webkit-mask-image: none;
    cursor: default;
  }

  #carousel-outer.grid-mode #carousel-track {
    transform: none !important;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    justify-content: center;
    padding: 0;
  }

  /* cards reset */
  #carousel-outer.grid-mode .carousel-slide {
    width: 100% !important;
    transform: none !important;
    opacity: 1 !important;
    transition: none !important;
    height: auto;
    min-height: 200px;
    cursor: pointer;
  }

  /* Mobile: show compact by default */
  #carousel-outer.grid-mode .carousel-slide .card-compact {
    display: flex !important;
  }

  #carousel-outer.grid-mode .carousel-slide .card-expanded {
    display: none !important;
  }

  /* Mobile: when expanded, show expanded and hide compact */
  #carousel-outer.grid-mode .carousel-slide.expanded .card-compact {
    display: none !important;
  }

  #carousel-outer.grid-mode .carousel-slide.expanded .card-expanded {
    display: flex !important;
  }

  /* Mobile: expanded details animation */
  #carousel-outer.grid-mode .carousel-slide .expanded-details {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(.4,0,.2,1), opacity 0.4s ease;
  }

  #carousel-outer.grid-mode .carousel-slide.expanded .expanded-details {
    max-height: 400px;
    opacity: 1;
  }

  /* ── Slide ──────────────────────────────────── */
  .carousel-slide {
    flex-shrink: 0;
    transform-origin: center top;
    border-radius: 12px;
    background: var(--bg-card);
    position: relative;
    cursor: pointer;
  }

  /* Spinning border on center card */
  .carousel-slide::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: var(--border);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: background 0.35s ease;
    pointer-events: none;
    z-index: 1;
  }
  .carousel-slide[data-center="true"]::before {
    background: conic-gradient(from var(--angle), #7b61ff, #06b6d4, #ec4899, #f59e0b, #7b61ff);
    animation: spin-gradient 2.5s linear infinite;
  }

  @property --angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }
  @keyframes spin-gradient {
    from { --angle: 0deg; }
    to   { --angle: 360deg; }
  }

  /* ── Compact card ───────────────────────────── */
  .card-compact {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px;
  }

  /* ── Expanded card ──────────────────────────── */
  .card-expanded {
    display: none;
    flex-direction: column;
  }

  .expanded-details {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
  }
  .expanded-details.open {
    max-height: 600px;
    opacity: 1;
  }

  /* ── Image zone ─────────────────────────────── */
  .card-image-zone {
    width: 100%;
    height: 200px;
    border-radius: 11px 11px 0 0;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: color-mix(in srgb, var(--accent) 6%, var(--bg-card));
    border-bottom: 1px solid var(--border);
  }
  .placeholder-title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text);
    opacity: 0.25;
  }
  .placeholder-type {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* ── Expanded meta ──────────────────────────── */
  .expanded-meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px 24px 18px;
    border-bottom: 1px solid var(--border);
  }

  /* ── Learned section ────────────────────────── */
  .expanded-learned {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .learned-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .learned-list li {
    font-size: 0.82rem;
    color: var(--text);
    opacity: 0.85;
    line-height: 1.55;
    padding: 8px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .learned-list li:last-child { border-bottom: none; }
  .learned-list li::before {
